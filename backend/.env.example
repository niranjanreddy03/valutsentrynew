# Vault Sentry backend — example env file. Copy to backend/.env for local
# dev. In production (Render), set these in the Render dashboard.

# Core
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=replace-with-a-strong-random-string

# CORS — comma-separated list of allowed frontend origins. Never use "*".
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Database (Supabase Postgres connection string, or local SQLite for dev)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# Redis (Render injects this automatically when linked to vaultsentry-redis)
REDIS_URL=redis://localhost:6379/0

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# GitHub
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Notifications
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=alerts@yourdomain.com
