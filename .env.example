# ========================================
# Vault Sentry Environment Variables
# ========================================
# Copy this file to .env and update values

# ----------------------------------------
# Database Configuration
# ----------------------------------------
POSTGRES_USER=VaultSentry
POSTGRES_PASSWORD=VaultSentry123
POSTGRES_DB=VaultSentry

# ----------------------------------------
# Redis Configuration
# ----------------------------------------
REDIS_PASSWORD=redis123

# ----------------------------------------
# Security Configuration
# ----------------------------------------
# IMPORTANT: Change this in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ----------------------------------------
# Application Configuration
# ----------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ----------------------------------------
# Frontend Configuration
# ----------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NODE_ENV=development

# ----------------------------------------
# Cloudflare Turnstile (Captcha)
# ----------------------------------------
# Frontend site key — rendered on login / register / forgot-password.
# Get it from: https://dash.cloudflare.com → Turnstile → Add site.
# The matching SECRET key must be pasted into:
#   Supabase Dashboard → Authentication → Attack Protection → CAPTCHA
# Leave blank to disable captcha (pages auto-hide the widget).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-side secret — used by /api/support to verify tokens via
# Cloudflare's siteverify endpoint. Also paste into Supabase Dashboard →
# Authentication → Attack Protection → CAPTCHA for auth-flow enforcement.
# Leave blank in dev to skip verification.
TURNSTILE_SECRET_KEY=

# ----------------------------------------
# GitHub Integration (Optional)
# ----------------------------------------
# Create a GitHub App at: https://github.com/settings/apps
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----------------------------------------
# GitLab Integration (Optional)
# ----------------------------------------
GITLAB_TOKEN=
GITLAB_BASE_URL=https://gitlab.com

# ----------------------------------------
# AWS Integration (Optional)
# ----------------------------------------
# For S3 bucket scanning
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ----------------------------------------
# Email Configuration (Optional)
# ----------------------------------------
# For sending alerts and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@VaultSentry.io

# ----------------------------------------
# Slack Integration (Optional)
# ----------------------------------------
# For Slack notifications
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# ----------------------------------------
# Monitoring (Optional)
# ----------------------------------------
GRAFANA_PASSWORD=admin123
SENTRY_DSN=

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ----------------------------------------
# Razorpay Payment Gateway
# ----------------------------------------
# Get keys from https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_*) in dev, live keys (rzp_live_*) in prod.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Configure in Razorpay Dashboard → Settings → Webhooks (events:
# payment.captured, payment.failed). Used by /api/razorpay/webhook
# to verify event signatures.
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Currency for charges. Razorpay defaults to INR. USD requires
# enabling international payments on your Razorpay account.
RAZORPAY_CURRENCY=INR

# ----------------------------------------
# Supabase Service Role (server-only)
# ----------------------------------------
# Required so /api/razorpay/verify and /api/razorpay/webhook can write
# verified payment state into the users table bypassing RLS.
# NEVER expose to the client — this is a server-only secret.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----------------------------------------
# Subscription API feature flag
# ----------------------------------------
# Set to 'true' once the FastAPI /api/v1/subscription/* routes exist.
# Leave unset to use local TIER_LIMITS/DEFAULT_PLANS fallbacks.
NEXT_PUBLIC_SUBSCRIPTION_API_ENABLED=
