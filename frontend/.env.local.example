# Frontend environment variables (Next.js)
#
# 1. Copy this file to `.env.local` in the same directory.
# 2. Fill in the values from your Supabase project:
#      Supabase Dashboard → Project Settings → API
#    - Project URL  → NEXT_PUBLIC_SUPABASE_URL
#    - `anon public` key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#      (do NOT use the `service_role` key here — it's exposed to the browser)
# 3. Restart the dev server (`npm run dev`) — Next.js only reads env files at startup.

# Required — without these, any page using Supabase (auth, etc.) will crash.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional — backend API base URL. Defaults to http://localhost:8000/api/v1.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
