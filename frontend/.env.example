# Frontend env. Copy to frontend/.env.local for local dev. In production
# (Vercel), set these in the Vercel project Settings → Environment Variables.

# Public URL of the FastAPI backend on Render
NEXT_PUBLIC_API_URL=https://vaultsentry-api.onrender.com

# Supabase (public/anon credentials only — never put service-role keys here)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
